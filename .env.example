# NAJDA environment — copy to .env for local development: cp .env.example .env
# The backend reads this file via dotenv; `make dev` also exports it for the frontend.

# --- Postgres (docker-compose.dev.yml creates this user/database on first start) ---
POSTGRES_USER=najda
POSTGRES_PASSWORD=najda
POSTGRES_DB=najda
# Host port the dev Postgres container publishes on 127.0.0.1.
# If another Postgres already uses 5432 on your machine, set 5433 here
# and change the port in DATABASE_URL below to match.
POSTGRES_PORT=5432

# Connection string the backend (sqlx) uses.
DATABASE_URL=postgres://najda:najda@localhost:5432/najda

# --- Redis ---
# Host port the dev Redis container publishes on 127.0.0.1.
REDIS_PORT=6379
# Connection string the backend uses.
REDIS_URL=redis://localhost:6379

# --- Backend ---
# The API listens on PORT (default 8080). Leave it unset in local dev:
# `make dev` exports this whole file, and PORT would also affect the
# frontend dev server.
# PORT=8080

# Log filter for the backend (tracing EnvFilter syntax, e.g. info,api=debug).
RUST_LOG=info

# Directory where missing-person photos are stored (created at startup;
# relative paths resolve against the backend process working directory).
UPLOAD_DIR=uploads

# --- Frontend ---
# Base URL the frontend server uses for server-side calls to the backend.
# Local dev: the backend on localhost. In Docker: http://backend:8080
API_INTERNAL_URL=http://localhost:8080
